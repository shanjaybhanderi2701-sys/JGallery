<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- MANAGE_EXTERNAL_STORAGE is declared by :core:storage and merged in — the app module
         itself declares no storage permissions (the boundary owns the permission model). -->

    <!-- Media3/ExoPlayer's library manifest merges this in for bandwidth metering. JGallery only
         ever plays local files, and the §9.3 "never uploaded" claim requires zero network-capable
         permissions (APP-289 egress guard enforces it) — so strip it at merge. ExoPlayer degrades
         gracefully (network type reads as unknown). -->
    <uses-permission
        android:name="android.permission.ACCESS_NETWORK_STATE"
        tools:node="remove" />

    <!-- Delegated capture straight into an album (APP-424): JGallery hands a MediaStore EXTRA_OUTPUT
         uri to the *system camera* so the camera app writes the bytes. JGallery therefore declares NO
         CAMERA permission (declaring-but-ungranted would break ACTION_IMAGE_CAPTURE — Security gate
         APP-426). These <queries> give the capture intents package visibility on Android 11+ so the
         launcher resolves a camera app; absence is handled gracefully (ActivityNotFoundException → no-op). -->
    <queries>
        <intent>
            <action android:name="android.media.action.IMAGE_CAPTURE" />
        </intent>
        <intent>
            <action android:name="android.media.action.VIDEO_CAPTURE" />
        </intent>
    </queries>

    <application
        android:name=".JGalleryApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.JGallery">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.JGallery">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
